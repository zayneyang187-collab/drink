.search-row {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  border-radius: 12rpx;
  height: 72rpx;
  padding: 0 16rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.row-actions {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-start;
}

.row-actions button {
  margin-right: 12rpx;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
}

.item-sub {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}
