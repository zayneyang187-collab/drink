.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  color: #1C1C1E;
  font-size: 26rpx;
}

.badge-item {
  margin-top: 12rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 12rpx;
}

.badge-item.earned {
  background: #FFF9F0;
  border-color: rgba(255, 159, 10, 0.35);
}