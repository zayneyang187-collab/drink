.profile-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.badge-item {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 10rpx;
}

.badge-item.earned {
  background: #fff7ed;
  border-color: #fdba74;
}

.badge-title {
  display: block;
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}

.badge-sub {
  margin-top: 4rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.list-item,
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.list-item:last-child,
.history-item:last-child {
  border-bottom: none;
}

.list-main {
  flex: 1;
  margin-right: 16rpx;
}

.list-name {
  display: block;
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}

.list-sub {
  margin-top: 4rpx;
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.link {
  font-size: 24rpx;
  color: #ea580c;
}

.link.danger {
  color: #dc2626;
}
