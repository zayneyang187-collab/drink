.action-links {
  margin-top: 16rpx;
}

.mini-share {
  padding: 0;
  margin: 0;
  background: transparent;
  color: #FF9F0A;
  font-size: 24rpx;
  line-height: 1;
}

.mini-share::after {
  border: none;
}

.dim-row {
  margin-top: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.dim-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}