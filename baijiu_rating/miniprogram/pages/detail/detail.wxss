.head-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  display: block;
}

.sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
  display: block;
}

.tag-row {
  margin-top: 12rpx;
}

.img-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.photo {
  display: inline-block;
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  background: #f3f4f6;
}

.actions {
  margin-top: 18rpx;
}

.action-btn {
  margin-bottom: 10rpx;
}

.scene-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.scene-item:last-child {
  border-bottom: none;
}

.scene-top {
  display: flex;
  justify-content: space-between;
}

.scene-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.scene-score {
  font-size: 32rpx;
  color: #c2410c;
  font-weight: 700;
}

.scene-sub {
  color: #6b7280;
  font-size: 22rpx;
}

.dim-card {
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #e5e7eb;
}

.dim-card:last-child {
  border-bottom: none;
}

.dim-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  display: block;
}

.dim-line {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4b5563;
  display: block;
}

.review-item {
  border-bottom: 1rpx solid #f3f4f6;
  padding: 12rpx 0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-head {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.review-text {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #1f2937;
}
