.guide-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.guide-box {
  width: 560rpx;
  border-radius: 20rpx;
  background: #ffffff;
  padding: 32rpx;
  text-align: center;
}

.guide-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.guide-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.step {
  margin-bottom: 20rpx;
}

.step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 10rpx;
  display: block;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
}

.chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.chip-active {
  background: #ffedd5;
  color: #c2410c;
  border: 1rpx solid #fdba74;
}

.mt12 {
  margin-top: 12rpx;
}

.rank-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.small-actions {
  display: flex;
}

.action-text {
  color: #ea580c;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-index {
  width: 48rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.rank-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rank-name {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
}

.rank-sub {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.rank-score {
  font-size: 30rpx;
  color: #c2410c;
  font-weight: 700;
}
