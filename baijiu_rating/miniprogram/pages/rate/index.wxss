.field {
  margin-top: 14rpx;
}

.picker,
.input,
.textarea {
  margin-top: 8rpx;
  background: #EFEFF4;
  border-radius: 12rpx;
  padding: 14rpx;
  font-size: 24rpx;
  color: #1C1C1E;
}

.textarea {
  min-height: 130rpx;
}

.link-btn {
  margin-top: 8rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  color: #FF9F0A;
  background: #FFFFFF;
  border-radius: 12rpx;
}

.link-btn::after {
  border: none;
}

.img-row {
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #F8F8FA;
}