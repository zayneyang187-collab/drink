.field {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #374151;
  margin-bottom: 8rpx;
}

.picker,
.input,
.textarea {
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 14rpx;
  font-size: 24rpx;
  color: #111827;
}

.textarea {
  min-height: 140rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.image-list {
  margin-top: 10rpx;
}

.image-item {
  background: #fff7ed;
  border-radius: 10rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.image-text {
  flex: 1;
  font-size: 22rpx;
  color: #7c2d12;
  margin-right: 12rpx;
}

.delete {
  font-size: 22rpx;
  color: #dc2626;
}
